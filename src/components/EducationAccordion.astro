---
interface LinkItem {
  label?: string;
  href?: string;
  text: string;
}

interface Section {
  id: string;
  collapseId: string;
  title: string;
  items: LinkItem[];
}

const { sections } = Astro.props as { sections: Section[] };
---

{
  sections.map((section) => (
    <div class="accordion mb-3" id={section.id}>
      <div class="accordion-item">
        <h5 class="accordion-header">
          <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target={`#${section.collapseId}`}
            aria-expanded="false"
            aria-controls={section.collapseId}
          >
            {section.title}
          </button>
        </h5>
        <div
          id={section.collapseId}
          class="accordion-collapse collapse"
          data-bs-parent={`#${section.id}`}
        >
          <div class="accordion-body">
            <div class="panel-kicker">Learning Node</div>
            <ul class="mb-0">
              {
                section.items.map((item) => (
                  <li>
                    {item.label ? <strong>{item.label}: </strong> : null}
                    {item.href ? <a href={item.href}>{item.text}</a> : item.text}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  ))
}
