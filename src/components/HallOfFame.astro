---
import GalleryModal from "./GalleryModal.astro";
import ProjectGallery from "./ProjectGallery.astro";

type Bullet =
  | string
  | {
      href?: string;
      label?: string;
      text: string;
    };

interface Project {
  id: string;
  title?: string;
  group?: string;
  groupName?: string;
  intro?: string;
  description?: string;
  extraParagraphs?: string[];
  implementationTags?: string[];
  bullets: Bullet[];
  images?: string[];
}

interface HallYear {
  year: string;
  id: string;
  projects: Project[];
}

type TextBlock =
  | {
      type: "paragraph";
      text: string;
    }
  | {
      type: "heading";
      level: 2 | 3 | 4 | 5 | 6;
      text: string;
    }
  | {
      type: "list";
      items: string[];
    };

const { years } = Astro.props as { years: HallYear[] };
const filterTags = Array.from(
  new Set(
    years.flatMap((year) => year.projects.flatMap((project) => project.implementationTags ?? [])),
  ),
).sort((left, right) => left.localeCompare(right));

const getProjectGroup = (project: Project) => {
  if (project.groupName) return project.groupName;
  if (project.group) return project.group;
  if (project.title) return project.title;

  const groupBullet = project.bullets.find(
    (bullet) => typeof bullet === "string" && bullet.trim().toLowerCase().startsWith("csapat:"),
  );
  return typeof groupBullet === "string"
    ? groupBullet.replace(/^csapat:\s*/i, "").trim()
    : undefined;
};

const getDisplayBullets = (project: Project) =>
  project.bullets.filter(
    (bullet) => !(typeof bullet === "string" && bullet.trim().toLowerCase().startsWith("csapat:")),
  );

const getProjectHeading = (project: Project) => project.title ?? getProjectGroup(project) ?? "Hall of fame project";

const bulletLinePattern = /^(?:[-*•◦▪‣]|(?:\d+\.))\s+/;
const markdownHeadingPattern = /^(#{1,6})\s+(.+)$/;

const escapeHtml = (text: string) =>
  text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");

const formatInlineMarkdown = (text: string) => {
  const escaped = escapeHtml(text);

  return escaped
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/__(.+?)__/g, "<strong>$1</strong>")
    .replace(/\*(.+?)\*/g, "<em>$1</em>")
    .replace(/_(.+?)_/g, "<em>$1</em>");
};

const parseTextBlocks = (text?: string): TextBlock[] => {
  if (!text) return [];

  const normalizedText = text
    .replace(/\r\n?/g, "\n")
    // YAML folded blocks often collapse markdown list items onto one line.
    .replace(/([:;.!?])\s*(?=(?:[*-]|\d+\.)\s)/g, "$1\n")
    .replace(/\s+(?=(?:[*-]|\d+\.)\s)/g, "\n")
    .trim()
;

  const sections = normalizedText
    .split(/\n\s*\n/)
    .map((section) => section.trim())
    .filter(Boolean);

  return sections.flatMap((section) => {
    const lines = section
      .split("\n")
      .map((line) => line.trim())
      .filter(Boolean);

    const blocks: TextBlock[] = [];
    let listItems: string[] = [];

    const flushListItems = () => {
      if (!listItems.length) return;
      blocks.push({
        type: "list",
        items: listItems,
      });
      listItems = [];
    };

    for (const line of lines) {
      if (bulletLinePattern.test(line)) {
        listItems.push(line.replace(bulletLinePattern, "").trim());
        continue;
      }

      flushListItems();

      const headingMatch = line.match(markdownHeadingPattern);
      if (headingMatch) {
        blocks.push({
          type: "heading" as const,
          level: Math.min(Math.max(headingMatch[1].length + 1, 2), 6) as 2 | 3 | 4 | 5 | 6,
          text: headingMatch[2].trim(),
        });
        continue;
      }

      blocks.push({
        type: "paragraph" as const,
        text: line,
      });
    }

    flushListItems();

    return blocks;
  });
};

---

<div class="hall-of-fame-filter">
  <div class="panel-kicker">Filter by tags</div>
  <div class="hall-of-fame-filter-bar" aria-hidden="true"></div>
  {
    filterTags.length ? (
      <div class="hall-of-fame-filter-tags" aria-label="Project tag filters">
        {
          filterTags.map((tag) => (
            <button
              class="hall-of-fame-filter-tag"
              type="button"
              data-hall-filter-tag={tag}
              aria-pressed="false"
            >
              {tag}
            </button>
          ))
        }
      </div>
    ) : null
  }
</div>

<div id="halloffame" class="carousel slide">
  <div class="carousel-inner">
    {
      years.map((year, yearIndex) => (
        <section class:list={["carousel-item", { active: yearIndex === 0 }]}>
          <div class="hall-of-fame-year">
            <div class="year-header">
              <div class="panel-kicker">Archive Cycle</div>
              <h5>{year.year}</h5>
            </div>
            <div class="accordion" id={year.id}>
              {
                year.projects.map((project) => (
                  (() => {
                    const group = getProjectGroup(project);
                    const projectHeading = getProjectHeading(project);
                    const displayBullets = getDisplayBullets(project);
                    return (
                  <div
                    class="accordion-item"
                    data-hall-project
                    data-tags={(project.implementationTags ?? []).join("|")}
                  >
                    <h5 class="accordion-header">
                      <div class="accordion-header-row">
                        <button
                          class="accordion-title-button"
                          type="button"
                          data-gallery-modal-open={`${project.id}-modal`}
                        >
                          <span class="accordion-title-copy">
                            <span>{projectHeading}</span>
                            {group ? <span class="accordion-group-name">{group}</span> : null}
                          </span>
                        </button>
                        <button
                          class="accordion-toggle-button collapsed"
                          type="button"
                          data-bs-toggle="collapse"
                          data-bs-target={`#${project.id}`}
                          aria-expanded="false"
                          aria-controls={project.id}
                        >
                          <span class="visually-hidden">Toggle details for {projectHeading}</span>
                        </button>
                      </div>
                    </h5>
                    <div
                      id={project.id}
                      class="accordion-collapse collapse"
                      data-bs-parent={`#${year.id}`}
                    >
                      <div class="accordion-body">
                        <div class="panel-kicker">Featured Build</div>
                        <div class="project-actions">
                          <GalleryModal
                            id={`${project.id}-modal`}
                            title={projectHeading}
                            subtitle={year.year}
                            description={project.description ?? project.intro ?? "Hall of fame project"}
                            details={[
                              ...(group ? [`Csapat: ${group}`] : []),
                              ...(project.implementationTags?.map((tag) => `Technologia: ${tag}`) ?? []),
                              ...displayBullets.slice(0, 6),
                            ]}
                            images={project.images ?? []}
                            triggerLabel="Projekt popup"
                            triggerClass="project-modal-trigger"
                          />
                        </div>
                        <div class="implementation-tags" aria-label="Project metadata tags">
                          {group ? <span class="implementation-tag group-tag">{group}</span> : null}
                          {project.implementationTags?.map((tag) => (
                            <span class="implementation-tag">{tag}</span>
                          ))}
                        </div>
                        {project.intro ? (
                          <div class="formatted-copy formatted-copy-intro">
                            {parseTextBlocks(project.intro).map((block) =>
                              block.type === "list" ? (
                                <ul class="formatted-copy-list">
                                  {block.items.map((item) => (
                                    <li set:html={formatInlineMarkdown(item)} />
                                  ))}
                                </ul>
                              ) : block.type === "heading" ? (
                                block.level === 2 ? (
                                  <h2 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : block.level === 3 ? (
                                  <h3 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : block.level === 4 ? (
                                  <h4 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : block.level === 5 ? (
                                  <h5 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : (
                                  <h6 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                )
                              ) : (
                                <p set:html={formatInlineMarkdown(block.text)} />
                              ),
                            )}
                          </div>
                        ) : null}
                        {project.description ? (
                          <div class="formatted-copy">
                            {parseTextBlocks(project.description).map((block) =>
                              block.type === "list" ? (
                                <ul class="formatted-copy-list">
                                  {block.items.map((item) => (
                                    <li set:html={formatInlineMarkdown(item)} />
                                  ))}
                                </ul>
                              ) : block.type === "heading" ? (
                                block.level === 2 ? (
                                  <h2 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : block.level === 3 ? (
                                  <h3 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : block.level === 4 ? (
                                  <h4 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : block.level === 5 ? (
                                  <h5 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                ) : (
                                  <h6 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                )
                              ) : (
                                <p set:html={formatInlineMarkdown(block.text)} />
                              ),
                            )}
                          </div>
                        ) : null}
                        {project.extraParagraphs?.length ? (
                          <div class="formatted-copy">
                            {project.extraParagraphs.map((paragraph) =>
                              parseTextBlocks(paragraph).map((block) =>
                                block.type === "list" ? (
                                  <ul class="formatted-copy-list">
                                    {block.items.map((item) => (
                                      <li set:html={formatInlineMarkdown(item)} />
                                    ))}
                                  </ul>
                                ) : block.type === "heading" ? (
                                  block.level === 2 ? (
                                    <h2 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                  ) : block.level === 3 ? (
                                    <h3 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                  ) : block.level === 4 ? (
                                    <h4 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                  ) : block.level === 5 ? (
                                    <h5 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                  ) : (
                                    <h6 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                  )
                                ) : (
                                  <p set:html={formatInlineMarkdown(block.text)} />
                                ),
                              ),
                            )}
                          </div>
                        ) : null}
                        <ul>
                          {
                            displayBullets.map((bullet) => (
                              <li>
                                {typeof bullet === "string" ? (
                                  bullet
                                ) : bullet.href ? (
                                  <a href={bullet.href} target="_blank" rel="noreferrer">
                                    {bullet.text}
                                  </a>
                                ) : (
                                  <div class="formatted-copy formatted-copy-compact">
                                    {bullet.label ? <strong>{bullet.label}: </strong> : null}
                                    {parseTextBlocks(bullet.text).map((block) =>
                                      block.type === "list" ? (
                                        <ul class="formatted-copy-list">
                                          {block.items.map((item) => (
                                            <li set:html={formatInlineMarkdown(item)} />
                                          ))}
                                        </ul>
                                      ) : block.type === "heading" ? (
                                        block.level === 2 ? (
                                          <h2 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                        ) : block.level === 3 ? (
                                          <h3 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                        ) : block.level === 4 ? (
                                          <h4 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                        ) : block.level === 5 ? (
                                          <h5 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                        ) : (
                                          <h6 class="formatted-copy-heading" set:html={formatInlineMarkdown(block.text)} />
                                        )
                                      ) : (
                                        <p set:html={formatInlineMarkdown(block.text)} />
                                      ),
                                    )}
                                  </div>
                                )}
                              </li>
                            ))
                          }
                        </ul>
                        {
                          project.images?.length ? (
                            <ProjectGallery
                              id={`${project.id}-gallery`}
                              title={projectHeading}
                              images={project.images}
                            />
                          ) : null
                        }
                      </div>
                    </div>
                  </div>
                    );
                  })()
                ))
              }
            </div>
          </div>
        </section>
      ))
    }
  </div>
  <button
    class="carousel-control-prev"
    type="button"
    data-bs-target="#halloffame"
    data-bs-slide="next"
  >
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button
    class="carousel-control-next"
    type="button"
    data-bs-target="#halloffame"
    data-bs-slide="prev"
  >
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

<script is:inline>
  (() => {
    const filterButtons = Array.from(document.querySelectorAll("[data-hall-filter-tag]"));
    const projectItems = Array.from(document.querySelectorAll("[data-hall-project]"));
    if (!filterButtons.length || !projectItems.length) return;
    if (window.__hallOfFameFilterReady) return;
    window.__hallOfFameFilterReady = true;

    const selectedTags = new Set();

    const render = () => {
      filterButtons.forEach((button) => {
        const tag = button.getAttribute("data-hall-filter-tag") ?? "";
        const isActive = selectedTags.has(tag);
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      projectItems.forEach((item) => {
        const tags = (item.getAttribute("data-tags") ?? "")
          .split("|")
          .filter(Boolean);
        const matches =
          selectedTags.size === 0 || tags.some((tag) => selectedTags.has(tag));
        item.toggleAttribute("hidden", !matches);
      });
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.getAttribute("data-hall-filter-tag");
        if (!tag) return;

        if (selectedTags.has(tag)) {
          selectedTags.delete(tag);
        } else {
          selectedTags.add(tag);
        }

        render();
      });
    });

    render();
  })();
</script>
